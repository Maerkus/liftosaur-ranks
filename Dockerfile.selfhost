# API server image for the self-hosted deployment (see SELFHOST.md)
FROM node:22-bookworm-slim

WORKDIR /app

COPY package.json package-lock.json ./
RUN npm ci --ignore-scripts

COPY . .
RUN test -f localdomain.js || cp localdomain.default.js localdomain.js

ENV TS_NODE_TRANSPILE_ONLY=1
EXPOSE 3000
CMD ["npx", "ts-node", "server.ts"]
