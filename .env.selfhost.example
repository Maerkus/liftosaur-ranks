# Copy to .env.selfhost and fill in. Generate secrets with: openssl rand -hex 32

# Session cookie signing secret (changing it logs everyone out)
LFT_COOKIE_SECRET=

# Admin API key (used for admin/debug endpoints - keep it secret)
LFT_API_KEY=

# Encryption key for short-lived tokens/links
LFT_CRYPTO_KEY=

# Public origin the app is served from. For local use keep localhost;
# for phone access set your Tailscale/tunnel domain, e.g. https://lift.tailXXXX.ts.net
HOST=http://localhost:8080

# Extra origins allowed by CORS, comma-separated host[:port] (no protocol).
# Same-origin deployments only need the host from HOST above.
LFT_ALLOWED_HOSTS=localhost:8080

# Optional: force a cookie domain. Leave empty for a host-only cookie (recommended).
# LFT_COOKIE_DOMAIN=

# Optional: version stamp shown in the app / used for cache busting
# COMMIT_HASH=selfhost

# Optional: enable AI program generation by providing your own key (costs money per use)
# LFT_ANTHROPIC_KEY=
# LFT_OPENAI_KEY=
